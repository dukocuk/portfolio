<svg viewBox="0 0 1200 800" xmlns="http://www.w3.org/2000/svg" font-family="'Segoe UI', 'Helvetica Neue', Arial, sans-serif">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#1b2233"/>
      <stop offset="1" stop-color="#0e1420"/>
    </linearGradient>
    <linearGradient id="accent" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#6ea8fe"/>
      <stop offset="1" stop-color="#8f7bff"/>
    </linearGradient>
    <pattern id="grid" width="48" height="48" patternUnits="userSpaceOnUse">
      <path d="M48 0H0V48" fill="none" stroke="#ffffff" stroke-opacity="0.035" stroke-width="1"/>
    </pattern>
  </defs>

  <rect width="1200" height="800" fill="url(#bg)"/>
  <rect width="1200" height="800" fill="url(#grid)"/>

  <!-- soft glow -->
  <circle cx="600" cy="330" r="220" fill="url(#accent)" opacity="0.10"/>

  <!-- lock icon -->
  <g transform="translate(600 300)">
    <rect x="-70" y="-10" width="140" height="120" rx="20" fill="none" stroke="url(#accent)" stroke-width="6"/>
    <path d="M-42 -10 v-28 a42 42 0 0 1 84 0 v28" fill="none" stroke="url(#accent)" stroke-width="6" stroke-linecap="round"/>
    <circle cx="0" cy="42" r="13" fill="url(#accent)"/>
    <rect x="-5" y="48" width="10" height="30" rx="5" fill="url(#accent)"/>
  </g>

  <text x="600" y="500" text-anchor="middle" fill="#f4f6fb" font-size="46" font-weight="700">No images available</text>

  <text x="600" y="552" text-anchor="middle" fill="#aab6cc" font-size="24" font-weight="400">Screenshots are omitted for confidentiality reasons.</text>
  <text x="600" y="588" text-anchor="middle" fill="#aab6cc" font-size="24" font-weight="400">The app was developed for a client.</text>

  <!-- tag chips -->
  <g fill="#8ea2c4" font-size="18" font-weight="600">
    <g transform="translate(430 650)">
      <rect x="0" y="0" width="120" height="40" rx="20" fill="#ffffff" fill-opacity="0.06" stroke="#ffffff" stroke-opacity="0.10"/>
      <text x="60" y="26" text-anchor="middle">C# · Xamarin</text>
    </g>
    <g transform="translate(566 650)">
      <rect x="0" y="0" width="140" height="40" rx="20" fill="#ffffff" fill-opacity="0.06" stroke="#ffffff" stroke-opacity="0.10"/>
      <text x="70" y="26" text-anchor="middle">ASP.NET Core</text>
    </g>
    <g transform="translate(722 650)">
      <rect x="0" y="0" width="48" height="40" rx="20" fill="#ffffff" fill-opacity="0.06" stroke="#ffffff" stroke-opacity="0.10"/>
      <text x="24" y="26" text-anchor="middle">·</text>
    </g>
  </g>
</svg>
